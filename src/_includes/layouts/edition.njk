---
layout: layouts/base.njk
---

<div class="container mx-auto px-4 md:px-8 max-w-5xl">

    <!-- ABOUT SECTION -->
    <section id="about" class="mb-20">
        <div class="space-y-6 text-lg text-slate-700 leading-relaxed font-light prose prose-indigo max-w-none">
            {{ content | safe }}
        </div>
    </section>

    <!-- INSTRUCTIONAL TEAM SECTION -->
    <section id="speakers" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-heading text-slate-900 mb-8 border-l-4 border-indigo-600 pl-4">
            Instructional Team (Speakers & TAs)
        </h2>
        <div class="overflow-x-auto border border-slate-200 rounded-xl">
            <table class="w-full text-left text-sm md:text-base border-collapse">
              <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 uppercase tracking-wider text-xs font-semibold">
                <tr>
                  <th scope="col" class="px-6 py-3">Week</th>
                  <th scope="col" class="px-6 py-3">Course</th>
                  <th scope="col" class="px-6 py-3">Speaker</th>
                  <th scope="col" class="px-6 py-3">Teaching Assistant</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                {% for weekObj in speakers %}
                  {% for course in weekObj.courses %}
                    <tr>
                      {% if loop.first %}
                        <td rowspan="{{ weekObj.courses.length }}" class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 align-top border-r border-gray-200">
                          <b>{{ weekObj.week }}</b><br>
                          <span class="text-gray-500 text-xs font-normal">({{ weekObj.dates }})</span>
                        </td>
                      {% endif %}
                      <td class="px-6 py-4 whitespace-wrap text-sm text-gray-900 align-top font-semibold">{{ course.name }}</td>
                      <td class="px-6 py-4 whitespace-wrap text-sm text-gray-700 align-top">{{ course.speaker | safe }}</td>
                      <td class="px-6 py-4 whitespace-wrap text-sm text-gray-700 align-top">{{ course.ta | safe }}</td>
                    </tr>
                  {% endfor %}
                {% endfor %}
              </tbody>
            </table>
        </div>
    </section>

    <!-- Course Resource Grid Section (Replaces Syllabus) -->
    <section id="courses" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-8 border-l-4 border-indigo-600 pl-4">
            Syllabus
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <a href="univmath/" target="_self" class="group flex flex-col items-center justify-center p-8 bg-white border border-slate-200 rounded-2xl hover:border-indigo-600 hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300">
                <span class="text-slate-900 font-bold font-roboto text-lg text-center group-hover:text-indigo-600 transition-colors">Intro to University Mathematics</span>
                <span class="mt-2 text-indigo-600 text-sm font-medium group-hover:translate-x-1 transition-transform">See Details &rarr;</span>
            </a>
            <a href="analysis/" target="_self" class="group flex flex-col items-center justify-center p-8 bg-white border border-slate-200 rounded-2xl hover:border-indigo-600 hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300">
                <span class="text-slate-900 font-bold font-roboto text-lg text-center group-hover:text-indigo-600 transition-colors">Analysis</span>
                <span class="mt-2 text-indigo-600 text-sm font-medium group-hover:translate-x-1 transition-transform">See Details &rarr;</span>
            </a>
            <a href="algebra/" target="_self" class="group flex flex-col items-center justify-center p-8 bg-white border border-slate-200 rounded-2xl hover:border-indigo-600 hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300">
                <span class="text-slate-900 font-bold font-roboto text-lg text-center group-hover:text-indigo-600 transition-colors">Algebra</span>
                <span class="mt-2 text-indigo-600 text-sm font-medium group-hover:translate-x-1 transition-transform">See Details &rarr;</span>
            </a>
            <a href="linear_algebra/" target="_self" class="group flex flex-col items-center justify-center p-8 bg-white border border-slate-200 rounded-2xl hover:border-indigo-600 hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300">
                <span class="text-slate-900 font-bold font-roboto text-lg text-center group-hover:text-indigo-600 transition-colors">Linear Algebra</span>
                <span class="mt-2 text-indigo-600 text-sm font-medium group-hover:translate-x-1 transition-transform">See Details &rarr;</span>
            </a>
        </div>
    </section>

    <!-- SCHEDULE SECTION -->
    <section id="schedule" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-8">
            Lecture Schedule
        </h2>
        <div class="mb-8 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="p-6 bg-indigo-50/50 border border-indigo-100 rounded-xl">
                <h3 class="font-bold text-indigo-900 mb-3 font-roboto text-xl">Morning Session</h3>
                <ul class="space-y-2 text-slate-700 font-light">
                    <li class="flex justify-between border-b border-indigo-100/50 pb-2"><span>Lecture</span> <span class="font-medium text-slate-900">09:30 AM &ndash; 11:00 AM</span></li>
                    <li class="flex justify-between border-b border-indigo-100/50 pb-2 text-indigo-600"><span>Tea Break</span> <span>11:00 AM &ndash; 11:30 AM</span></li>
                    <li class="flex justify-between"><span>Tutorial</span> <span class="font-medium text-slate-900">11:30 AM &ndash; 01:00 PM</span></li>
                </ul>
            </div>
            <div class="p-6 bg-emerald-50/50 border border-emerald-100 rounded-xl">
                <h3 class="font-bold text-emerald-900 mb-3 font-roboto text-xl">Afternoon Session</h3>
                <ul class="space-y-2 text-slate-700 font-light">
                    <li class="flex justify-between border-b border-emerald-100/50 pb-2"><span>Lecture</span> <span class="font-medium text-slate-900">02:00 PM &ndash; 03:30 PM</span></li>
                    <li class="flex justify-between border-b border-emerald-100/50 pb-2 text-emerald-600"><span>Tea Break</span> <span>03:30 PM &ndash; 03:45 PM</span></li>
                    <li class="flex justify-between"><span>Tutorial</span> <span class="font-medium text-slate-900">03:45 PM &ndash; 05:15 PM</span></li>
                </ul>
            </div>
        </div>

        <div class="overflow-x-auto border border-slate-200 rounded-xl">
            {% macro getSpeaker(courseName, currentWeekStr, editionSpeakers) %}
              {% set found = "" %}
              {% for weekObj in editionSpeakers %}
                {% if weekObj.week == currentWeekStr %}
                  {% for crs in weekObj.courses %}
                    {% if crs.name == courseName %}
                       {% set found = crs.short_speaker + " &ndash; " + crs.short_ta %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endfor %}
              {{ found | safe }}
            {% endmacro %}
            
            <table class="w-full text-left text-sm md:text-base border-collapse">
              <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 uppercase tracking-wider text-xs font-semibold">
                <tr>
                  <th scope="col" class="px-6 py-3 w-1/4">Date</th>
                  <th scope="col" class="px-6 py-3 w-3/8">Morning Session</th>
                  <th scope="col" class="px-6 py-3 w-3/8">Afternoon Session</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                {% set currentWeekStr = "" %}
                {% for row in schedules %}
                  {% if row.type == "week" %}
                    {% set currentWeekStr = row.label %}
                    <tr class="bg-indigo-50/30 border-y-2 border-indigo-100">
                      <td colspan="3" class="px-6 py-3 whitespace-nowrap text-sm font-bold text-indigo-900 text-center uppercase tracking-widest">{{ row.label }}</td>
                    </tr>
                  {% else %}
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 align-top">{{ row.date }}</td>
                      <td class="px-6 py-4 whitespace-wrap text-sm text-gray-700 align-top">
                         <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-semibold {{ site.colors[row.morning].badge if site.colors[row.morning] else site.colors['Default'].badge }}">{{ row.morning }}</span><br>
                         <span class="text-xs text-slate-500 mt-1 block">{{ getSpeaker(row.morning, currentWeekStr, speakers) }}</span>
                      </td>
                      <td class="px-6 py-4 whitespace-wrap text-sm text-gray-700 align-top">
                         <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-semibold {{ site.colors[row.afternoon].badge if site.colors[row.afternoon] else site.colors['Default'].badge }}">{{ row.afternoon }}</span><br>
                         <span class="text-xs text-slate-500 mt-1 block">{{ getSpeaker(row.afternoon, currentWeekStr, speakers) }}</span>
                      </td>
                    </tr>
                  {% endif %}
                {% endfor %}
              </tbody>
            </table>
        </div>
    </section>

    <!-- SELECTED CANDIDATES SECTION -->
    <section id="selectedcandidates" class="mb-20">
        <h2
            class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-8 border-l-4 border-indigo-600 pl-4">
            Selected Candidates for SWIM@KSoM {{ edition }}
        </h2>
        <div class="mt-8 space-y-12">
            {% set categories = [
                { id: "accommodation", label: "Participants Requiring Accommodation" },
                { id: "local", label: "Local Participants (No Accommodation Required)" }
            ] %}
            
            {% for cat in categories %}
                {% set list = participants[cat.id] %}
                {% if list %}
                <div>
                    <h3 class="text-xl font-bold font-heading text-slate-900 mb-6 flex items-center">
                        <span class="w-2 h-8 bg-indigo-600 mr-3 rounded-full"></span>
                        {{ cat.label }}
                    </h3>
                    <div class="overflow-x-auto border border-slate-200 rounded-xl">
                        <table class="w-full text-left text-sm md:text-base border-collapse">
                            <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 uppercase tracking-wider text-xs font-semibold">
                                <tr>
                                    <th scope="col" class="px-6 py-3 w-20">Sl. No.</th>
                                    <th scope="col" class="px-6 py-3">Application ID</th>
                                    <th scope="col" class="px-6 py-3">Name</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                {% for participant in list %}
                                    <tr>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ participant.sl_no }}</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-600">
                                            <span class="bg-slate-100 px-2 py-0.5 rounded text-xs">{{ participant.app_id }}</span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ participant.name | safe }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                {% endif %}
            {% endfor %}
        </div>
    </section>

</div>
