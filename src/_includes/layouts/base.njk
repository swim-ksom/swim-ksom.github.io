<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("SWIM@KSoM - Summer Workshop in Mathematics") }}</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        playfair: ['Playfair Display', 'serif'],
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
        rel="stylesheet">
    <!-- Local CSS -->
    <!-- Eleventy gives us absolute root path for styles when built -->
    <link rel="stylesheet" href="/style.css">
    <!-- MathJax -->
    <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
</head>

<body
    class="bg-white min-h-screen flex flex-col antialiased text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <header id="header" class="relative z-50 bg-white border-b border-slate-200">
        {% include "components/header.njk" %}
    </header>

    <main class="flex-grow w-full{{ ' pt-12 pb-20' if is_edition_page else '' }}">
        {{ content | safe }}
    </main>

    {% include "components/footer.njk" %}

    <!-- Scripts -->
    <script src="/script.js"></script>
</body>

</html>
