---
layout: layouts/base.njk
---
{% set courseColor = site.colors[course_title] if site.colors[course_title] else site.colors['Default'] %}
<div class="container mx-auto px-4 md:px-8 max-w-5xl">

    <section id="course-description-box" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-8 border-l-4 {{ courseColor.border }} pl-4">{{ course_title }}</h2>
        <div class="text-lg text-slate-600 font-light leading-relaxed prose prose-indigo max-w-none">
            {{ content | safe }}
        </div>
    </section>

    <section id="lecture-schedule-box" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-8 border-l-4 {{ courseColor.border }} pl-4">Lecture Schedule & Resources</h2>
        <div class="overflow-x-auto border border-slate-200 rounded-xl">
            <table class="w-full text-left text-sm md:text-base border-collapse">
                <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 uppercase tracking-wider text-xs font-semibold">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Lecture
                        </th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Topics Covered
                        </th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Speaker
                        </th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Resources (Notes/Problems)
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {% for lecture in lectures %}
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 align-top">Lecture {{ loop.index }}<br><span class="text-gray-500 text-xs font-normal">{{ lecture.date }}</span></td>
                        <td class="px-6 py-4 whitespace-wrap text-sm text-gray-700 align-top">{{ lecture.topics }}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 align-top">{{ lecture.speaker | safe }} <br> TA: {{ lecture.ta }}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 align-top">
                            {% if lecture.resources and lecture.resources.length > 0 %}
                                {% for res in lecture.resources %}
                                    <a href="{{ res.url }}" target="_blank" class="{{ courseColor.text }} hover:underline">{{ res.title }}</a>{% if not loop.last %}<br>{% endif %}
                                {% endfor %}
                            {% else %}
                                Coming Soon
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</div>
