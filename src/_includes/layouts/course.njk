---
layout: layouts/base.njk
---
{% from "macros.njk" import getSpeaker %}
{% set courseColor = site.colors[course_id] if site.colors[course_id] else site.colors['Default'] %}
<div class="container mx-auto px-4 md:px-8 max-w-5xl">

    <section id="course-description-box" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-8 border-l-4 {{ courseColor.border }} pl-4">{{ course_title }}</h2>
        <div class="text-lg text-slate-600 font-light leading-relaxed prose prose-indigo max-w-none">
            {{ content | safe }}
        </div>
    </section>

    <section id="lecture-schedule-box" class="mb-20">
        <h2 class="text-2xl md:text-3xl font-bold font-roboto text-slate-900 mb-4 border-l-4 {{ courseColor.border }} pl-4">Lecture Schedule & Resources</h2>
        <div class="mb-8 p-4 bg-amber-50 border-l-4 border-amber-400 text-amber-800 rounded-r-lg text-sm shadow-sm">
            <p class="font-medium flex items-center">
                <svg class="w-5 h-5 mr-2 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                </svg>
                Note: The schedule is tentative and may be subject to change during the program.
            </p>
        </div>
        <div class="overflow-x-auto border border-slate-200 rounded-xl">
            <table class="min-w-[800px] w-full text-left text-sm md:text-base border-collapse">
                <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 uppercase tracking-wider text-xs font-semibold">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Lecture
                        </th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Topics Covered
                        </th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Speaker
                        </th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">
                            Resources (Notes/Problems)
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {% set lectureCount = [0] %}
                    {% set currentWeekStr = "" %}
                    {% for row in schedules %}
                      {% if row.type == "week" %}
                        {% set currentWeekStr = row.label %}
                      {% else %}
                        {% for session in [row.morning, row.afternoon] %}
                          {% if session %}
                            {% set sParts = session.split(':') %}
                            {% if sParts[0] == course_id %}
                              {% set idx = lectureCount[0] %}
                              {% set lectureInfo = lectures[idx] %}
                              <tr>
                                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 align-top">Lecture {{ idx + 1 }}<br><span class="text-gray-500 text-xs font-normal">{{ row.date }}</span></td>
                                  <td class="px-6 py-4 whitespace-wrap text-sm text-gray-700 align-top">{{ lectureInfo.topics }}</td>
                                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 align-top">{{ getSpeaker(session, currentWeekStr, speakers) }}</td>
                                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 align-top">
                                      {% if lectureInfo.resources and lectureInfo.resources.length > 0 %}
                                          {% for res in lectureInfo.resources %}
                                              <a href="{{ res.url }}" target="_blank" class="{{ courseColor.text }} hover:underline">{{ res.title }}</a>{% if not loop.last %}<br>{% endif %}
                                          {% endfor %}
                                      {% else %}
                                          Coming Soon
                                      {% endif %}
                                  </td>
                              </tr>
                              {% set _ = lectureCount.push(lectureCount.pop() + 1) %}
                            {% endif %}
                          {% endif %}
                        {% endfor %}
                      {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</div>
